{
  "name": "@fast-knowledge/web",
  "version": "1.0.0",
  "license": "AGPL-3.0-or-later",
  "description": "Fast Knowledge 快速知识库 Web 前端",
  "keywords": [
    "knowledge-base",
    "vue3",
    "vite",
    "element-plus",
    "rag",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lixuanqun/fast-knowledge.git",
    "directory": "frontend"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,scss}\"",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "@tanstack/vue-query": "^5.66.0",
    "axios": "^1.7.7",
    "dompurify": "^3.2.4",
    "element-plus": "^2.8.4",
    "marked": "^14.1.3",
    "pinia": "^2.2.4",
    "vue": "^3.5.12",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.19.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-vue": "^9.32.0",
    "globals": "^15.14.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.4.2",
    "sass": "^1.80.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.22.0",
    "unplugin-auto-import": "^19.1.0",
    "unplugin-vue-components": "^28.4.0",
    "vite": "^6.0.0",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^3.0.5",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^2.1.6"
  }
}
